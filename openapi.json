{
  "openapi": "3.0.3",
  "info": {
    "title": "Crabbase API",
    "description": "API for managing collections and their records",
    "version": "0.1.0"
  },
  "servers": [
    {
      "url": "http://localhost:8989/api",
      "description": "Local development server"
    }
  ],
  "security": [
    { "bearerAuth": [] }
  ],
  "paths": {
    "/openapi.json": {
      "get": {
        "tags": ["Docs"],
        "summary": "Get OpenAPI spec",
        "operationId": "getOpenApi",
        "security": [],
        "responses": {
          "200": {
            "description": "OpenAPI JSON",
            "content": {
              "application/json": {
                "schema": { "type": "object" }
              }
            }
          }
        }
      }
    },
    "/docs": {
      "get": {
        "tags": ["Docs"],
        "summary": "Swagger UI",
        "operationId": "getDocs",
        "security": [],
        "responses": {
          "200": {
            "description": "Swagger UI HTML",
            "content": {
              "text/html": {
                "schema": { "type": "string" }
              }
            }
          }
        }
      }
    },
    "/collections": {
      "get": {
        "tags": ["Collections"],
        "summary": "List all collections",
        "operationId": "listCollections",
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "description": "Page number (default: 1)",
            "schema": {
              "type": "integer",
              "minimum": 1
            }
          },
          {
            "name": "per_page",
            "in": "query",
            "description": "Items per page (default: 20, max: 100)",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 100
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Paginated list of collections",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CollectionListResponse"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorBody"
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": ["Collections"],
        "summary": "Create a new collection",
        "operationId": "createCollection",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateCollectionRequest"
              },
              "examples": {
                "allDataTypes": {
                  "summary": "Collection with all data types",
                  "description": "Example collection demonstrating every available column data type",
                  "value": {
                    "name": "products",
                    "columns": [
                      {
                        "name": "title",
                        "data_type": "PlainText",
                        "index": true,
                        "related_to": null
                      },
                      {
                        "name": "description",
                        "data_type": "RichText",
                        "index": false,
                        "related_to": null
                      },
                      {
                        "name": "price",
                        "data_type": "Number",
                        "index": false,
                        "related_to": null
                      },
                      {
                        "name": "active",
                        "data_type": "Bool",
                        "index": false,
                        "related_to": null
                      },
                      {
                        "name": "contact_email",
                        "data_type": "Email",
                        "index": false,
                        "related_to": null
                      },
                      {
                        "name": "website",
                        "data_type": "Url",
                        "index": false,
                        "related_to": null
                      },
                      {
                        "name": "published_at",
                        "data_type": "Datetime",
                        "index": false,
                        "related_to": null
                      },
                      {
                        "name": "created_at",
                        "data_type": {"AutoDatetime": "now"},
                        "index": false,
                        "related_to": null
                      },
                      {
                        "name": "thumbnail",
                        "data_type": "File",
                        "index": false,
                        "related_to": null
                      },
                      {
                        "name": "category_id",
                        "data_type": "Relation",
                        "index": false,
                        "related_to": "categories"
                      },
                      {
                        "name": "status",
                        "data_type": "Select",
                        "index": false,
                        "related_to": null
                      },
                      {
                        "name": "metadata",
                        "data_type": "Json",
                        "index": false,
                        "related_to": null
                      },
                      {
                        "name": "location",
                        "data_type": "GeoPoint",
                        "index": false,
                        "related_to": null
                      }
                    ]
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Collection created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Collection"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorBody"
                }
              }
            }
          }
        }
      }
    },
    "/collections/{name}": {
      "get": {
        "tags": ["Collections"],
        "summary": "Get a collection by name",
        "operationId": "getCollection",
        "parameters": [
          {
            "name": "name",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Collection details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Collection"
                }
              }
            }
          },
          "404": {
            "description": "Collection not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorBody"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorBody"
                }
              }
            }
          }
        }
      },
      "patch": {
        "tags": ["Collections"],
        "summary": "Update a collection",
        "operationId": "updateCollection",
        "parameters": [
          {
            "name": "name",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateCollectionRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Collection updated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Collection"
                }
              }
            }
          },
          "400": {
            "description": "Invalid input",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorBody"
                }
              }
            }
          },
          "404": {
            "description": "Collection not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorBody"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorBody"
                }
              }
            }
          }
        }
      },
      "delete": {
        "tags": ["Collections"],
        "summary": "Delete a collection",
        "operationId": "deleteCollection",
        "parameters": [
          {
            "name": "name",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Collection deleted",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "detail": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorBody"
                }
              }
            }
          }
        }
      }
    },
    "/collections/{name}/truncate": {
      "post": {
        "tags": ["Collections"],
        "summary": "Truncate a collection (delete all records)",
        "operationId": "truncateCollection",
        "parameters": [
          {
            "name": "name",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Collection truncated",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "detail": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorBody"
                }
              }
            }
          }
        }
      }
    },
    "/collections/{name}/records": {
      "get": {
        "tags": ["Records"],
        "summary": "List records in a collection",
        "operationId": "listRecords",
        "parameters": [
          {
            "name": "name",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "page",
            "in": "query",
            "description": "Page number (default: 1)",
            "schema": {
              "type": "integer",
              "minimum": 1
            }
          },
          {
            "name": "per_page",
            "in": "query",
            "description": "Items per page (default: 20, max: 100)",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 100
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Paginated list of records",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RecordListResponse"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorBody"
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": ["Records"],
        "summary": "Create a new record in a collection",
        "operationId": "createRecord",
        "parameters": [
          {
            "name": "name",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateRecordRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Record created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Record"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorBody"
                }
              }
            }
          }
        }
      }
    },
    "/auth/{collection}/login": {
      "post": {
        "tags": ["Auth"],
        "summary": "Authenticate user and receive JWT token",
        "operationId": "login",
        "security": [],
        "parameters": [
          {
            "name": "collection",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Authentication successful",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LoginResponse"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorBody"
                }
              }
            }
          }
        }
      }
    },
    "/auth/profile": {
      "get": {
        "tags": ["Auth"],
        "summary": "Get authenticated user's profile",
        "operationId": "getProfile",
        "responses": {
          "200": {
            "description": "User profile",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserProfile"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorBody"
                }
              }
            }
          }
        }
      }
    },
    "/auth/{collection}/auth-refresh": {
      "post": {
        "tags": ["Auth"],
        "summary": "Refresh authentication token with email verification",
        "description": "Refreshes an authentication token by validating the provided refresh token and email address. The email is used to verify the token belongs to the correct user in the specified collection.",
        "operationId": "refreshToken",
        "security": [],
        "parameters": [
          {
            "name": "collection",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Collection name for the authentication context"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AuthRefreshRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Token refreshed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LoginResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorBody"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorBody"
                }
              }
            }
          }
        }
      }
    },

    "/collections/{name}/records/{id}": {
      "get": {
        "tags": ["Records"],
        "summary": "Get a record by ID",
        "operationId": "getRecord",
        "parameters": [
          {
            "name": "name",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Record details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Record"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorBody"
                }
              }
            }
          }
        }
      },
      "patch": {
        "tags": ["Records"],
        "summary": "Update a record",
        "operationId": "updateRecord",
        "parameters": [
          {
            "name": "name",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateRecordRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Record updated",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "details": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorBody"
                }
              }
            }
          }
        }
      },
      "delete": {
        "tags": ["Records"],
        "summary": "Delete a record",
        "operationId": "deleteRecord",
        "parameters": [
          {
            "name": "name",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Record deleted",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "details": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorBody"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "Collection": {
        "type": "object",
        "required": ["id", "name", "system", "collection_type", "fields", "indexes", "created", "updated"],
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique collection identifier"
          },
          "name": {
            "type": "string",
            "description": "Collection name (unique)"
          },
          "system": {
            "type": "boolean",
            "description": "Whether this is a system collection"
          },
          "collection_type": {
            "type": "string",
            "description": "Type of collection (e.g., auth, base)"
          },
          "fields": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Column"
            },
            "description": "Column definitions for the collection"
          },
          "indexes": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Column"
            },
            "description": "Index definitions for the collection"
          },
          "list_rule": {
            "type": "string",
            "nullable": true,
            "description": "Rule for listing records in this collection"
          },
          "view_rule": {
            "type": "string",
            "nullable": true,
            "description": "Rule for viewing individual records in this collection"
          },
          "create_rule": {
            "type": "string",
            "nullable": true,
            "description": "Rule for creating records in this collection"
          },
          "update_rule": {
            "type": "string",
            "nullable": true,
            "description": "Rule for updating records in this collection"
          },
          "delete_rule": {
            "type": "string",
            "nullable": true,
            "description": "Rule for deleting records in this collection"
          },
          "options": {
            "$ref": "#/components/schemas/CollectionOptions",
            "description": "Collection configuration options"
          },
          "created": {
            "type": "string",
            "format": "date-time",
            "description": "Collection creation timestamp"
          },
          "updated": {
            "type": "string",
            "format": "date-time",
            "description": "Collection last update timestamp"
          }
        }
      },
      "CollectionOptions": {
        "type": "object",
        "properties": {
          "authToken": {
            "type": "object",
            "additionalProperties": true,
            "description": "Authentication token configuration for auth collections"
          }
        }
      },
      "CollectionListResponse": {
        "type": "object",
        "required": ["items", "total", "page", "per_page"],
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Collection"
            }
          },
          "total": {
            "type": "integer",
            "description": "Total number of collections"
          },
          "page": {
            "type": "integer",
            "description": "Current page number"
          },
          "per_page": {
            "type": "integer",
            "description": "Number of items per page"
          }
        }
      },
      "CreateCollectionRequest": {
        "type": "object",
        "required": ["name", "columns"],
        "properties": {
          "name": {
            "type": "string",
            "description": "Collection name (must be unique)"
          },
          "collection_type": {
            "type": "string",
            "nullable": true,
            "description": "Type of collection (optional)"
          },
          "columns": {
            "type": "array",
            "description": "Column definitions for the collection",
            "items": {
              "$ref": "#/components/schemas/Column"
            }
          }
        }
      },
      "UpdateCollectionRequest": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "New collection name (optional)"
          },
          "columns": {
            "type": "array",
            "description": "New column definitions for the collection (optional)",
            "items": {
              "$ref": "#/components/schemas/Column"
            }
          },
          "list_rule": {
            "type": "string",
            "nullable": true,
            "description": "Rule for listing records (optional)"
          },
          "view_rule": {
            "type": "string",
            "nullable": true,
            "description": "Rule for viewing records (optional)"
          },
          "create_rule": {
            "type": "string",
            "nullable": true,
            "description": "Rule for creating records (optional)"
          },
          "update_rule": {
            "type": "string",
            "nullable": true,
            "description": "Rule for updating records (optional)"
          },
          "delete_rule": {
            "type": "string",
            "nullable": true,
            "description": "Rule for deleting records (optional)"
          }
        }
      },
      "Column": {
        "type": "object",
        "required": ["name", "data_type", "index"],
        "properties": {
          "name": {
            "type": "string",
            "description": "Column name"
          },
          "data_type": {
            "$ref": "#/components/schemas/DataTypes",
            "description": "Column data type"
          },
          "index": {
            "type": "boolean",
            "description": "Whether to create an index on this column"
          },
          "hidden": {
            "type": "boolean",
            "default": false,
            "description": "Whether this column is hidden in responses"
          },
          "required": {
            "type": "boolean",
            "default": false,
            "description": "Whether this column is required"
          },
          "min": {
            "type": "integer",
            "nullable": true,
            "description": "Minimum value/length constraint"
          },
          "max": {
            "type": "integer",
            "nullable": true,
            "description": "Maximum value/length constraint"
          },
          "pattern": {
            "type": "string",
            "nullable": true,
            "description": "Regular expression pattern for validation"
          },
          "related_to": {
            "type": "string",
            "nullable": true,
            "description": "Related collection name for relation fields"
          }
        }
      },
      "DataTypes": {
        "oneOf": [
          {
            "type": "string",
            "enum": [
              "PlainText",
              "RichText",
              "Number",
              "Bool",
              "Email",
              "Url",
              "Datetime",
              "File",
              "Relation",
              "Select",
              "Json",
              "GeoPoint"
            ]
          },
          {
            "type": "object",
            "properties": {
              "AutoDatetime": {
                "type": "string",
                "description": "Auto-datetime mode (e.g. 'now', 'created', 'updated')"
              }
            },
            "required": ["AutoDatetime"]
          }
        ],
        "description": "Available column data types"
      },
      "Record": {
        "type": "object",
        "required": ["id", "data", "created", "updated"],
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique record identifier"
          },
          "data": {
            "type": "object",
            "additionalProperties": true,
            "description": "Flexible JSON object containing record data"
          },
          "created": {
            "type": "string",
            "description": "Record creation timestamp"
          },
          "updated": {
            "type": "string",
            "description": "Record last update timestamp"
          }
        }
      },
      "RecordListResponse": {
        "type": "object",
        "required": ["items", "total", "page", "per_page"],
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Record"
            }
          },
          "total": {
            "type": "integer",
            "description": "Total number of records"
          },
          "page": {
            "type": "integer",
            "description": "Current page number"
          },
          "per_page": {
            "type": "integer",
            "description": "Number of items per page"
          }
        }
      },
      "CreateRecordRequest": {
        "type": "object",
        "required": ["data"],
        "properties": {
          "data": {
            "type": "object",
            "additionalProperties": true,
            "description": "Flexible JSON object containing record data"
          }
        }
      },
      "UpdateRecordRequest": {
        "type": "object",
        "required": ["data"],
        "properties": {
          "data": {
            "type": "object",
            "additionalProperties": true,
            "description": "Flexible JSON object containing updated record data"
          }
        }
      },
      "ErrorBody": {
        "type": "object",
        "required": ["code", "message"],
        "properties": {
          "code": {
            "type": "string",
            "description": "Machine-readable error code"
          },
          "message": {
            "type": "string",
            "description": "Human-readable error message"
          },
          "details": {
            "description": "Optional additional error details"
          }
        }
      },
      "LoginRequest": {
        "type": "object",
        "required": ["email", "password"],
        "properties": {
          "email": {
            "type": "string",
            "description": "User's email"
          },
          "password": {
            "type": "string",
            "description": "User's password"
          }
        }
      },
      "LoginResponse": {
        "type": "object",
        "required": ["tokens"],
        "properties": {
          "tokens": {
            "$ref": "#/components/schemas/AuthTokens"
          }
        }
      },
      "AuthTokens": {
        "type": "object",
        "required": ["accessToken", "refreshToken"],
        "properties": {
          "accessToken": {
            "type": "string",
            "description": "JWT access token"
          },
          "refreshToken": {
            "type": "string",
            "description": "JWT refresh token"
          }
        }
      },
      "AuthRefreshRequest": {
        "type": "object",
        "required": ["refreshToken", "email"],
        "properties": {
          "refreshToken": {
            "type": "string",
            "description": "JWT refresh token to be used for obtaining new tokens"
          },
          "email": {
            "type": "string",
            "description": "Email address of the user requesting token refresh"
          }
        }
      },
      "UserProfile": {
        "type": "object",
        "required": ["id", "email"],
        "properties": {
          "id": { "type": "string", "description": "User ID" },
          "email": { "type": "string", "description": "User email" }
        }
      },
      "AuthClaims": {
        "type": "object",
        "description": "JWT token claims",
        "properties": {
          "type": {
            "type": "string",
            "description": "Token type (auth, verification, file)"
          },
          "id": {
            "type": "string",
            "description": "User ID"
          },
          "collectionId": {
            "type": "string",
            "description": "Associated collection ID"
          },
          "refreshable": {
            "type": "boolean",
            "description": "Whether the token can be refreshed"
          },
          "sub": {
            "type": "string",
            "description": "Subject (user ID)"
          },
          "exp": {
            "type": "integer",
            "description": "Expiration timestamp"
          },
          "iat": {
            "type": "integer",
            "description": "Issued at timestamp"
          }
        }
      }
    }
  }
