{
  "openapi": "3.0.3",
  "info": {
    "title": "Crabbase API",
    "description": "API for managing collections and their records",
    "version": "0.1.0"
  },
  "servers": [
    {
      "url": "http://localhost:8000/api",
      "description": "Local development server"
    }
  ],
  "paths": {
    "/collections": {
      "get": {
        "tags": ["Collections"],
        "summary": "List all collections",
        "operationId": "listCollections",
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "description": "Page number (default: 1)",
            "schema": {
              "type": "integer",
              "minimum": 1
            }
          },
          {
            "name": "per_page",
            "in": "query",
            "description": "Items per page (default: 20, max: 100)",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 100
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Paginated list of collections",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CollectionListResponse"
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": ["Collections"],
        "summary": "Create a new collection",
        "operationId": "createCollection",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateCollectionRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Collection created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Collection"
                }
              }
            }
          },
          "409": {
            "description": "Collection already exists"
          },
          "501": {
            "description": "Not yet implemented"
          }
        }
      }
    },
    "/collections/{name}": {
      "get": {
        "tags": ["Collections"],
        "summary": "Get a collection by name",
        "operationId": "getCollection",
        "parameters": [
          {
            "name": "name",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Collection details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Collection"
                }
              }
            }
          },
          "404": {
            "description": "Collection not found"
          }
        }
      },
      "patch": {
        "tags": ["Collections"],
        "summary": "Update a collection",
        "operationId": "updateCollection",
        "parameters": [
          {
            "name": "name",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateCollectionRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Collection updated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Collection"
                }
              }
            }
          },
          "400": {
            "description": "Invalid input"
          },
          "404": {
            "description": "Collection not found"
          },
          "500": {
            "description": "Internal server error"
          }
        }
      },
      "delete": {
        "tags": ["Collections"],
        "summary": "Delete a collection",
        "operationId": "deleteCollection",
        "parameters": [
          {
            "name": "name",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Collection deleted",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "detail": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "500": {
            "description": "Internal server error"
          }
        }
      }
    },
    "/collections/{name}/truncate": {
      "post": {
        "tags": ["Collections"],
        "summary": "Truncate a collection (delete all records)",
        "operationId": "truncateCollection",
        "parameters": [
          {
            "name": "name",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Collection truncated",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "detail": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "500": {
            "description": "Internal server error"
          }
        }
      }
    },
    "/collections/{name}/records": {
      "get": {
        "tags": ["Records"],
        "summary": "List records in a collection",
        "operationId": "listRecords",
        "parameters": [
          {
            "name": "name",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "page",
            "in": "query",
            "description": "Page number (default: 1)",
            "schema": {
              "type": "integer",
              "minimum": 1
            }
          },
          {
            "name": "per_page",
            "in": "query",
            "description": "Items per page (default: 20, max: 100)",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 100
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Paginated list of records",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RecordListResponse"
                }
              }
            }
          },
          "404": {
            "description": "Collection not found"
          }
        }
      },
      "post": {
        "tags": ["Records"],
        "summary": "Create a new record in a collection",
        "operationId": "createRecord",
        "parameters": [
          {
            "name": "name",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateRecordRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Record created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Record"
                }
              }
            }
          },
          "404": {
            "description": "Collection not found"
          }
        }
      }
    },
    "/collections/{name}/records/{id}": {
      "get": {
        "tags": ["Records"],
        "summary": "Get a record by ID",
        "operationId": "getRecord",
        "parameters": [
          {
            "name": "name",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Record details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Record"
                }
              }
            }
          },
          "404": {
            "description": "Record not found"
          }
        }
      },
      "patch": {
        "tags": ["Records"],
        "summary": "Update a record",
        "operationId": "updateRecord",
        "parameters": [
          {
            "name": "name",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateRecordRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Record updated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Record"
                }
              }
            }
          },
          "404": {
            "description": "Record not found"
          }
        }
      },
      "delete": {
        "tags": ["Records"],
        "summary": "Delete a record",
        "operationId": "deleteRecord",
        "parameters": [
          {
            "name": "name",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Record deleted"
          },
          "404": {
            "description": "Record not found"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Collection": {
        "type": "object",
        "required": ["id", "name", "fields", "indexes", "created", "updated"],
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique collection identifier"
          },
          "name": {
            "type": "string",
            "description": "Collection name (unique)"
          },
          "fields": {
            "type": "array",
            "items": {},
            "description": "Column definitions for the collection as JSON array"
          },
          "indexes": {
            "type": "array",
            "items": {},
            "description": "Index definitions for the collection as JSON array"
          },
          "created": {
            "type": "string",
            "format": "date-time",
            "description": "Collection creation timestamp"
          },
          "updated": {
            "type": "string",
            "format": "date-time",
            "description": "Collection last update timestamp"
          }
        }
      },
      "CollectionListResponse": {
        "type": "object",
        "required": ["items", "total", "page", "per_page"],
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Collection"
            }
          },
          "total": {
            "type": "integer",
            "description": "Total number of collections"
          },
          "page": {
            "type": "integer",
            "description": "Current page number"
          },
          "per_page": {
            "type": "integer",
            "description": "Number of items per page"
          }
        }
      },
      "CreateCollectionRequest": {
        "type": "object",
        "required": ["name", "columns"],
        "properties": {
          "name": {
            "type": "string",
            "description": "Collection name (must be unique)"
          },
          "columns": {
            "type": "array",
            "description": "Column definitions for the collection",
            "items": {
              "$ref": "#/components/schemas/Column"
            }
          }
        }
      },
      "UpdateCollectionRequest": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "New collection name (optional)"
          },
          "columns": {
            "type": "array",
            "description": "New column definitions for the collection (optional)",
            "items": {
              "$ref": "#/components/schemas/Column"
            }
          }
        }
      },
      "Column": {
        "type": "object",
        "required": ["name", "data_type", "index"],
        "properties": {
          "name": {
            "type": "string",
            "description": "Column name"
          },
          "data_type": {
            "$ref": "#/components/schemas/DataTypes",
            "description": "Column data type"
          },
          "index": {
            "type": "boolean",
            "description": "Whether to create an index on this column"
          }
        }
      },
      "DataTypes": {
        "type": "string",
        "enum": [
          "PlainText",
          "RichText",
          "Number",
          "Bool",
          "Email",
          "URL",
          "Datatime",
          "File",
          "Select",
          "JSON",
          "GeoPoint"
        ],
        "description": "Available column data types"
      },
      "Record": {
        "type": "object",
        "required": ["id", "data", "created", "updated"],
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique record identifier"
          },
          "data": {
            "type": "object",
            "additionalProperties": true,
            "description": "Flexible JSON object containing record data"
          },
          "created": {
            "type": "string",
            "format": "date-time",
            "description": "Record creation timestamp"
          },
          "updated": {
            "type": "string",
            "format": "date-time",
            "description": "Record last update timestamp"
          }
        }
      },
      "RecordListResponse": {
        "type": "object",
        "required": ["items", "total", "page", "per_page"],
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Record"
            }
          },
          "total": {
            "type": "integer",
            "description": "Total number of records"
          },
          "page": {
            "type": "integer",
            "description": "Current page number"
          },
          "per_page": {
            "type": "integer",
            "description": "Number of items per page"
          }
        }
      },
      "CreateRecordRequest": {
        "type": "object",
        "required": ["data"],
        "properties": {
          "data": {
            "type": "object",
            "additionalProperties": true,
            "description": "Flexible JSON object containing record data"
          }
        }
      },
      "UpdateRecordRequest": {
        "type": "object",
        "required": ["data"],
        "properties": {
          "data": {
            "type": "object",
            "additionalProperties": true,
            "description": "Flexible JSON object containing updated record data"
          }
        }
      }
    }
  }
}
